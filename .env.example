# Copy this file to `.env` and fill in the values.
# Only OPENAI_API_KEY is strictly required to run the agent examples.

# Required: model provider used by the DZap agent.
OPENAI_API_KEY=sk-...

# Optional: enable individual tools.
TAVILY_API_KEY=          # WebSearchTool + TrendingNews fallback
CRYPTOPANIC_API_KEY=     # TrendingNewsTool (primary source)
COINSTATS_API_KEY=       # CoinStats wrapper tools
MORALIS_API_KEY=         # Moralis wrapper tools

# Optional: a public wallet address used by the read-only examples.
# Defaults to a well-known public address if unset.
DEMO_WALLET_ADDRESS=0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045

# Optional: ONLY needed by the transaction-confirmation example (09).
# The example rejects every confirmation, so nothing is ever broadcast,
# but the SDK still expects a key on the account. Use a throwaway key.
DEMO_PRIVATE_KEY=
